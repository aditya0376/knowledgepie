          <div class="social-links">
            <a class="social-link" href="<%= social.linkedin %>" target="_blank" rel="noreferrer" aria-label="LinkedIn">
              <i class="fa-brands fa-linkedin-in"></i>
            </a>
            <a class="social-link" href="<%= social.twitter %>" target="_blank" rel="noreferrer" aria-label="X (Twitter)">
              <i class="fa-brands fa-x-twitter"></i>
            </a>
            <a class="social-link" href="<%= social.instagram %>" target="_blank" rel="noreferrer" aria-label="Instagram">
              <i class="fa-brands fa-instagram"></i>
            </a>
